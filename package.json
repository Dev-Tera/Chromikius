  "dependencies": {
    "canvas": "^3.2.3",
    "discord.js": "^14.15.3",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
